generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String
  email     String   @unique
  password  String
  jobRole   JobRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum JobRole {
  SUPERUSER
  ADMIN
  USER
}

enum FoodCategory {
  PROTEIN
  SIDE_DISH
  APPETIZER
  DRINK
  DESSERT
  SALAD
  FRUIT
  UTENSIL
}

enum MeasurementUnit {
  GRAM
  KILOGRAM
  MILLILITER
  LITER
  UNIT
}

model FoodItem {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  category    FoodCategory

  unit                 MeasurementUnit
  consumptionPerPerson Float
  wastePercentage      Float           @default(0)
  packageSize          Float?
  unitCost             Decimal?        @db.Decimal(10, 2)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("food_items")
}

model ConsumptionProfile {
  id              Int      @id @default(autoincrement())
  name            String
  adultEquivalent Float
  createdAt       DateTime @default(now())

  @@map("consumption_profiles")
}

model EventConsumptionModifier {
  id         Int       @id @default(autoincrement())
  eventType  EventType
  multiplier Float
  createdAt  DateTime  @default(now())
}
 
enum EventType {
  BBQ
  WEDDING
  CORPORATE
  BIRTHDAY
}
